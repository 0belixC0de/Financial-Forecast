# ShareForecast environment variables
#
# Market data uses Yahoo Finance and needs NO key.
#
# The ONLY optional key is for the AI news-sentiment layer of the forecast.
# Without it, forecasts still work using the math/statistical model.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for news analysis.
# Defaults to a current Claude model if unset.
# ANTHROPIC_MODEL=claude-opus-4-8
